# Shared root environment (Docker Compose source of truth)
APP_NAME=Pawn Loan API
APP_ENV=development
WEB_CLIENT_PORT=5173
API_SERVER_PORT=8000
POSTGRES_PORT=5432

POSTGRES_DB=pawn_loan_db
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=change_me

# API connection string used by api-server service
DATABASE_URL=postgresql+psycopg://your_postgres_user:change_me@postgres:5432/pawn_loan_db

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_USERNAME=admin
VITE_API_PASSWORD=change_me

# API security
JWT_SECRET_KEY=change_me_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_ROLE=administrator
DB_INIT_ON_STARTUP=true
DB_SEED_ON_STARTUP=true
DB_SEED_FORCE=false
AUTO_INTEREST_GENERATION_ENABLED=true
AUTO_INTEREST_GENERATION_INTERVAL_MINUTES=1440
