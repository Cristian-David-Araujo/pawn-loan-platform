# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT
SECRET_KEY=your-super-secret-key-change-in-production

# Token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service ports (optional overrides)
GATEWAY_PORT=8000
IDENTITY_SERVICE_PORT=8001
CUSTOMER_SERVICE_PORT=8002
LOAN_SERVICE_PORT=8003
COLLATERAL_SERVICE_PORT=8004
FINANCE_SERVICE_PORT=8005
PAYMENT_SERVICE_PORT=8006
REPORTING_SERVICE_PORT=8007
FRONTEND_PORT=80
